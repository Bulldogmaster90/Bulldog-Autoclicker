{
  "manifest_version": 3,
  "name": "Auto Clicker",
  "version": "1.0",
  "description": "Clique automaticamente na posição do mouse com intervalo personalizável.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
